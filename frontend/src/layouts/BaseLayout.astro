---
import '../styles/global.css';
import TopNavbar from '../components/navigation/TopNavbar.astro';
import Sidebar from '../components/navigation/Sidebar.astro';
import type { NavItem } from '../utils/navigation';

interface Props {
  title?: string;
  description?: string;
  navItems?: NavItem[];
  currentSlug?: string;
  showBack?: boolean;
  favicon?: string;
}

const { title, description, navItems = [], currentSlug, showBack = false, favicon } = Astro.props;

const hasSidebar = navItems.length > 0;
---

<!DOCTYPE html>
<html class="dark" lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link
      href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" href={favicon ?? '/favicon.svg'} type="image/svg+xml" />
    <title>{title ?? 'Development Manual'}</title>
    {description && <meta name="description" content={description} />}
  </head>
  <body>
    <TopNavbar siteTitle="Development Manual" showBack={showBack} />
    {hasSidebar ? (
      <div class="layout">
        <Sidebar items={navItems} currentSlug={currentSlug} />
        <main class="content">
          <slot />
        </main>
      </div>
    ) : (
      <main>
        <slot />
      </main>
    )}
  </body>
</html>

<style>
  .layout {
    display: flex;
    max-width: 1200px;
    margin: 0 auto;
  }
  .content {
    flex: 1;
    padding: 2rem;
    max-width: 800px;
  }
</style>
