---
export interface Props {
  siteTitle?: string;
  showBack?: boolean;
}

const { siteTitle = 'FastAPI Manual', showBack = false } = Astro.props;
---

<nav class="topnavbar" role="navigation" aria-label="Navegación principal">
  <div class="topnavbar__inner">
    <span class="topnavbar__brand" id="topnavbar-brand">{siteTitle}</span>
    {showBack && (
      <a href="/" class="topnavbar__back">
        <span class="material-symbols-outlined topnavbar__back-arrow">chevron_left</span>
        Regresar
      </a>
    )}
  </div>
</nav>

<style>
  .topnavbar {
    position: fixed;
    top: 0;
    width: 100%;
    z-index: 50;
    background: rgba(11, 19, 38, 0.8);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0 var(--margin-desktop);
    height: 64px;
  }

  .topnavbar__inner {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .topnavbar__brand {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 24px;
    line-height: 1.4;
    font-weight: 700;
    color: var(--primary);
    cursor: pointer;
  }

  .topnavbar__back {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    color: var(--on-surface-variant);
    text-decoration: none;
    font-family: 'Inter', sans-serif;
    font-size: 0.9rem;
    transition: color 0.2s;
    margin-left: 0.75rem;
    padding-left: 0.75rem;
    border-left: 1px solid var(--border-color);
  }

  .topnavbar__back:hover {
    color: var(--primary);
  }

  .topnavbar__back-arrow {
    font-size: 1rem;
    line-height: 1;
    font-weight: 700;
  }
</style>

<script>
  document.getElementById('topnavbar-brand')?.addEventListener('click', () => {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });
</script>
