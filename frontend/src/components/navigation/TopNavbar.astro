---
export interface Props {
  siteTitle?: string;
}

const { siteTitle = 'FastAPI Manual' } = Astro.props;
---

<nav class="topnavbar" role="navigation" aria-label="Navegación principal">
  <div class="topnavbar__inner">
    <span class="topnavbar__brand" id="topnavbar-brand">{siteTitle}</span>
  </div>
</nav>

<style>
  .topnavbar {
    position: fixed;
    top: 0;
    width: 100%;
    z-index: 50;
    background: rgba(11, 19, 38, 0.8);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0 var(--margin-desktop);
    height: 64px;
  }

  .topnavbar__inner {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .topnavbar__brand {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 24px;
    line-height: 1.4;
    font-weight: 700;
    color: var(--primary);
    cursor: pointer;
  }
</style>

<script>
  document.getElementById('topnavbar-brand')?.addEventListener('click', () => {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });
</script>
