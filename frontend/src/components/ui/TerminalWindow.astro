---
interface Props {
  title?: string;
}

const { title } = Astro.props;
---

<div class="terminal-window">
  <div class="terminal-window__header">
    <div class="terminal-window__dots">
      <div class="terminal-window__dot terminal-window__dot--red"></div>
      <div class="terminal-window__dot terminal-window__dot--yellow"></div>
      <div class="terminal-window__dot terminal-window__dot--green"></div>
    </div>
    {title && (
      <div class="terminal-window__title">
        <span class="terminal-window__title-text">{title}</span>
      </div>
    )}
  </div>
  <div class="terminal-window__body">
    <slot />
  </div>
</div>

<style>
  .terminal-window {
    width: 100%;
    background-color: var(--surface-container-lowest);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: var(--radius-xl);
    overflow: hidden;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
  }

  .terminal-window__header {
    background-color: var(--surface-container-high);
    padding: 0.75rem 1rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  .terminal-window__dots {
    display: flex;
    gap: 0.375rem;
    flex-shrink: 0;
  }

  .terminal-window__dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
  }

  .terminal-window__dot--red {
    background-color: #ff5f56;
  }

  .terminal-window__dot--yellow {
    background-color: #ffbd2e;
  }

  .terminal-window__dot--green {
    background-color: #27c93f;
  }

  .terminal-window__title {
    flex: 1;
    text-align: center;
  }

  .terminal-window__title-text {
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    line-height: 1.2;
    font-weight: 500;
    color: var(--on-surface-variant);
    opacity: 0.6;
  }

  .terminal-window__body {
    padding: 1.5rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: 14px;
    line-height: 1.5;
    font-weight: 400;
  }
</style>
