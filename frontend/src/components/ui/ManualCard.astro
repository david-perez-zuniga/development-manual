---
interface Topic {
  label: string;
  href: string;
}

interface Props {
  number: string;
  title: string;
  description: string;
  topics: Topic[];
}

const { number, title, description, topics } = Astro.props;
const cardId = `manual-card-${number}`;
const topicsId = `manual-topics-${number}`;
---

<div class="glass-card manual-card">
  <div class="manual-card__header" id={cardId} role="button" tabindex="0" aria-expanded="false" aria-controls={topicsId}>
    <span class="manual-card__number">{number}</span>
    <div class="manual-card__body">
      <h3 class="manual-card__title">{title}</h3>
      <p class="manual-card__description">{description}</p>
    </div>
    <div class="manual-card__action">
      <span class="manual-card__label">Ver temas</span>
      <span class="material-symbols-outlined manual-card__chevron">chevron_right</span>
    </div>
  </div>
  <div class="manual-card__topics hidden" id={topicsId} role="region" aria-labelledby={cardId}>
    {topics.map((topic) => (
      <a class="manual-card__topic" href={topic.href}>
        <span class="manual-card__bullet"></span>
        {topic.label}
      </a>
    ))}
  </div>
</div>

<style>
  .manual-card {
    padding: 1.5rem;
    border-radius: var(--radius-xl);
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .manual-card__header {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    cursor: pointer;
  }

  .manual-card__number {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 24px;
    line-height: 1.4;
    font-weight: 600;
    color: var(--primary);
    opacity: 0.5;
    transition: opacity 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    min-width: 2rem;
  }

  .manual-card:hover .manual-card__number {
    opacity: 1;
  }

  .manual-card__body {
    flex: 1;
  }

  .manual-card__title {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 24px;
    line-height: 1.4;
    font-weight: 600;
    color: var(--on-surface);
  }

  .manual-card__description {
    color: var(--on-surface-variant);
    font-size: 14px;
    margin-top: 0.25rem;
  }

  .manual-card__action {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--primary);
  }

  .manual-card__label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    line-height: 1.2;
    font-weight: 500;
    opacity: 0;
    transition: opacity 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .manual-card:hover .manual-card__label {
    opacity: 1;
  }

  .manual-card__chevron {
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .manual-card:hover .manual-card__chevron {
    transform: translateX(4px);
  }

  .manual-card__topics {
    display: none;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding-top: 1rem;
    gap: 0.5rem;
  }

  .manual-card__topics:not(.hidden) {
    display: grid;
    grid-template-columns: 1fr;
  }

  @media (min-width: 640px) {
    .manual-card__topics:not(.hidden) {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .manual-card__topic {
    font-size: 14px;
    color: var(--on-surface-variant);
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    transition: color 0.2s;
  }

  .manual-card__topic:hover {
    color: var(--primary);
  }

  .manual-card__bullet {
    width: 4px;
    height: 4px;
    background-color: var(--primary);
    border-radius: 50%;
    flex-shrink: 0;
  }

  .hidden {
    display: none !important;
  }
</style>

<script>
  const header = document.getElementById('{cardId}');
  const topics = document.getElementById('{topicsId}');

  function toggleTopics() {
    if (!header || !topics) return;
    const isHidden = topics.classList.contains('hidden');
    topics.classList.toggle('hidden');
    header.setAttribute('aria-expanded', String(!isHidden));
  }

  header?.addEventListener('click', toggleTopics);
  header?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' || e.key === ' ') {
      e.preventDefault();
      toggleTopics();
    }
  });
</script>
