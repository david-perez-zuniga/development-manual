---
interface Props {
  number: string;
  title: string;
  description: string;
  href?: string;
}

const { number, title, description, href = '/' } = Astro.props;
---

<div class="glass-card manual-card">
  <a class="manual-card__link" href={href}>
    <div class="manual-card__header">
      <span class="manual-card__number">{number}</span>
      <div class="manual-card__body">
        <h3 class="manual-card__title">{title}</h3>
        <p class="manual-card__description">{description}</p>
      </div>
      <div class="manual-card__action">
        <span class="material-symbols-outlined manual-card__chevron">chevron_right</span>
      </div>
    </div>
  </a>
</div>

<style>
  .manual-card {
    padding: 1.5rem;
    border-radius: var(--radius-xl);
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: border-color 0.2s;
  }

  .manual-card:hover {
    border-color: rgba(110, 229, 145, 0.3);
  }

  .manual-card__link {
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .manual-card__header {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .manual-card__number {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 24px;
    line-height: 1.4;
    font-weight: 600;
    color: var(--primary);
    opacity: 0.5;
    transition: opacity 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    min-width: 2rem;
  }

  .manual-card:hover .manual-card__number {
    opacity: 1;
  }

  .manual-card__body {
    flex: 1;
  }

  .manual-card__title {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 24px;
    line-height: 1.4;
    font-weight: 600;
    color: var(--on-surface);
    transition: color 0.2s;
  }

  .manual-card:hover .manual-card__title {
    color: var(--primary);
  }

  .manual-card__description {
    color: var(--on-surface-variant);
    font-size: 14px;
    margin-top: 0.25rem;
  }

  .manual-card__action {
    display: flex;
    align-items: center;
    color: var(--primary);
  }

  .manual-card__chevron {
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .manual-card:hover .manual-card__chevron {
    transform: translateX(4px);
  }
</style>


