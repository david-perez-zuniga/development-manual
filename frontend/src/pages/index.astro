---
import BaseLayout from '../layouts/BaseLayout.astro';
import ManualCard from '../components/ui/ManualCard.astro';
---

<BaseLayout title="Development Manual">
  <section class="hero">
    <div class="hero__ambient">
      <div class="hero__glow hero__glow--primary"></div>
      <div class="hero__glow hero__glow--secondary"></div>
    </div>
    <div class="hero__brand">
      <div class="hero__icon">
        <span class="material-symbols-outlined hero__terminal" style="font-variation-settings: 'FILL' 1;">terminal</span>
        <div class="hero__badge">
          <span class="material-symbols-outlined hero__bolt" style="font-variation-settings: 'FILL' 1;">bolt</span>
        </div>
      </div>
    </div>
    <h1 class="hero__title">Development Manual</h1>
    <div class="hero__actions">
      <a class="hero__cta" href="#manuals-section">
        Explorar Módulos
        <span class="material-symbols-outlined hero__arrow">arrow_forward</span>
      </a>
    </div>
  </section>
  <section class="manuals" id="manuals-section">
    <h2 class="manuals__heading">Manuales</h2>
    <div class="manuals__list">
      <ManualCard
        number="01"
        title="FastAPI"
        description="Domina la creaci&oacute;n de APIs modernas, r&aacute;pidas y tipadas con Python."
        href="/fastapi"
      />
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    position: relative;
    min-height: 60vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 6rem 1.5rem;
    text-align: center;
    overflow: hidden;
  }

  .hero__ambient {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 100%;
    height: 100%;
    pointer-events: none;
    opacity: 0.2;
  }

  .hero__glow {
    position: absolute;
    width: 24rem;
    height: 24rem;
    border-radius: 50%;
    filter: blur(120px);
  }

  .hero__glow--primary {
    top: 0;
    left: 25%;
    background-color: var(--primary);
  }

  .hero__glow--secondary {
    bottom: 0;
    right: 25%;
    background-color: var(--secondary);
  }

  .hero__brand {
    position: relative;
    margin-bottom: 2rem;
  }

  .hero__icon {
    width: 80px;
    height: 80px;
    background-color: var(--surface-container-high);
    border-radius: var(--radius-xl);
    border: 1px solid var(--border-color);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
  }

  .hero__terminal {
    font-size: 2.25rem;
    color: var(--primary);
  }

  .hero__badge {
    position: absolute;
    bottom: -4px;
    right: -4px;
    width: 24px;
    height: 24px;
    background-color: var(--secondary);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 2px solid var(--surface);
  }

  .hero__bolt {
    font-size: 0.75rem;
    color: var(--on-secondary-container);
  }

  .hero__title {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 48px;
    line-height: 1.2;
    letter-spacing: -0.02em;
    font-weight: 700;
    color: var(--primary);
    margin-bottom: 1rem;
    max-width: 48rem;
  }

  .hero__actions {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  @media (min-width: 640px) {
    .hero__actions {
      flex-direction: row;
    }
  }

  .hero__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background-color: var(--primary);
    color: var(--on-primary);
    font-weight: 500;
    padding: 0.75rem 2rem;
    border-radius: 9999px;
    text-decoration: none;
    transition: background-color 0.2s;
    box-shadow: 0 10px 15px -3px rgba(110, 229, 145, 0.2), 0 4px 6px -4px rgba(110, 229, 145, 0.2);
    cursor: pointer;
  }

  .hero__cta:hover {
    background-color: rgba(110, 229, 145, 0.9);
  }

  .hero__arrow {
    transition: transform 0.2s;
  }

  .hero__cta:hover .hero__arrow {
    transform: translateX(4px);
  }

  .manuals {
    max-width: 56rem;
    margin: 0 auto;
    padding: 6rem var(--margin-desktop);
  }

  .manuals__heading {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 32px;
    line-height: 1.25;
    font-weight: 600;
    color: var(--primary);
    margin-bottom: 3rem;
    text-align: center;
  }

  .manuals__list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

</style>

<script>
  // Atmospheric hover effects
  window.addEventListener('mousemove', (e) => {
    const x = (e.clientX / window.innerWidth) * 100;
    const y = (e.clientY / window.innerHeight) * 100;
    document.body.style.background = `radial-gradient(circle at ${x}% ${y}%, #0f172a 0%, #0b1326 100%)`;
  });

  // Smooth scrolling for anchor links on same page
  document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
    anchor.addEventListener('click', (e) => {
      const href = anchor.getAttribute('href');
      if (!href) return;
      const targetId = href.substring(1);
      const targetElement = document.getElementById(targetId);
      if (targetElement) {
        e.preventDefault();
        window.scrollTo({
          top: targetElement.offsetTop - 80,
          behavior: 'smooth',
        });
      }
    });
  });
</script>
