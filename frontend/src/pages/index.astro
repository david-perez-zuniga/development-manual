---
import BaseLayout from '../layouts/BaseLayout.astro';
import FeatureCard from '../components/ui/FeatureCard.astro';
---

<BaseLayout title="Development Manual - Inicio">
  <section class="hero">
    <h1 class="hero__title">Development Manual</h1>
    <p class="hero__description">Guía de desarrollo y buenas prácticas.</p>
  </section>

  <section class="features">
    <FeatureCard title="FastAPI" description="Guía completa para backend con FastAPI." />
  </section>
</BaseLayout>

<style>
  .hero {
    text-align: center;
    padding: 4rem 0;
  }
  .hero__title {
    font-size: 2.5rem;
    font-weight: 800;
    margin-bottom: 1rem;
  }
  .hero__description {
    color: #64748b;
    font-size: 1.2rem;
  }
  .features {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1rem;
  }
</style>
